{
  "name": "@luxwallet/ui",
  "version": "0.2.0",
  "description": "Shared, cross-target Lux Wallet UI component library built on @hanzo/gui. One component tree renders on web (react-native-web), browser extension, desktop, and native React Native.",
  "license": "MIT",
  "author": "Lux Wallet team",
  "repository": {
    "type": "git",
    "url": "https://github.com/luxwallet/ui.git"
  },
  "type": "module",
  "source": "src/index.ts",
  "main": "dist/cjs/index.cjs",
  "module": "dist/esm/index.mjs",
  "types": "./dist/types/index.d.ts",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/types/index.d.ts",
      "react-native": "./dist/esm/index.native.js",
      "browser": "./dist/esm/index.mjs",
      "module": "./dist/esm/index.mjs",
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.cjs",
      "default": "./dist/esm/index.mjs"
    },
    "./theme": {
      "types": "./dist/types/theme/index.d.ts",
      "react-native": "./dist/esm/theme/index.native.js",
      "browser": "./dist/esm/theme/index.mjs",
      "module": "./dist/esm/theme/index.mjs",
      "import": "./dist/esm/theme/index.mjs",
      "require": "./dist/cjs/theme/index.cjs",
      "default": "./dist/esm/theme/index.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LLM.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "@hanzo/gui": ">=7",
    "react": ">=18",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "typescript": "~5.9.2",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
